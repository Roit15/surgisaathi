# Public site URL — used for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://surgisaathi.com

# Google Apps Script Web App URL (the /exec endpoint). See google-apps-script.js
# for setup instructions.
GOOGLE_SCRIPT_URL=

# Shared HMAC secret. MUST match SHARED_SECRET in google-apps-script.js.
# Generate with: openssl rand -hex 32
GOOGLE_SCRIPT_SECRET=

# Optional: comma-separated list of additional Origins allowed to call the
# POST APIs (the request host is always allowed). Useful when serving from a
# preview deployment URL alongside the production domain.
# ALLOWED_ORIGINS=https://staging.surgisaathi.com

# --- Analytics (all optional) -------------------------------------------------
# Tags load only after the visitor accepts cookies via the consent banner.
# Leave blank to disable that tag entirely. Set the corresponding ID to
# activate the tag once you create the account in the provider's dashboard.

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Google Tag Manager container ID, e.g. GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Meta (Facebook) Pixel ID — for Meta Ads attribution & retargeting
NEXT_PUBLIC_META_PIXEL_ID=

# Microsoft Clarity project ID — free heatmaps & session recordings
NEXT_PUBLIC_CLARITY_ID=
